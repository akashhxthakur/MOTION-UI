{
  "name": "@motionui/playground",
  "version": "0.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build": "echo 'Playground uses Expo dev server'",
    "lint": "eslint app/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .expo node_modules/.cache"
  },
  "dependencies": {
    "@motionui/components": "workspace:*",
    "@motionui/theme": "workspace:*",
    "@motionui/tokens": "workspace:*",
    "expo": "~52.0.23",
    "expo-constants": "~17.0.3",
    "expo-linking": "~7.0.3",
    "expo-router": "~4.0.14",
    "expo-status-bar": "~2.0.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.5",
    "react-native-gesture-handler": "~2.21.2",
    "react-native-reanimated": "~3.16.5",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-web": "~0.19.13"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@motionui/eslint-config": "workspace:*",
    "@motionui/typescript-config": "workspace:*",
    "@types/react": "~18.3.18",
    "eslint": "^9.17.0",
    "typescript": "^5.7.2"
  }
}
